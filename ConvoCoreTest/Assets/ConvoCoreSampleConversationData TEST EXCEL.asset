--- !u!49 &-3187015049477895409
TextAsset:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_Name: EmbeddedYaml
  m_Script: "Conversation1:\r\n- CharacterID: Ava\r\n  LineID: L_eb24286502b8\r\n 
    LocalizedDialogue: {en: \"Jared... we're definitely off-trail.\", fr: \"Jared...
    on s'est clairement \xE9gar\xE9s.\", es: \"Jared... definitivamente nos perdimos
    del sendero.\"}\r\n- CharacterID: Jared\r\n  LineID: L_a5f15816cde2\r\n  LocalizedDialogue:
    {en: \"Technically, we're *still* in the forest. Nature counts.\", fr: \"Techniquement,
    on est toujours dans la for\xEAt. \xC7a compte, non?\", es: \"T\xE9cnicamente,
    seguimos en el bosque. Eso cuenta.\"}\r\n- CharacterID: Ava\r\n  LineID: L_1a39d08ee5ae\r\n 
    LocalizedDialogue: {en: \"We've circled that tree three times now.\", fr: \"On
    a tourn\xE9 autour de cet arbre trois fois.\", es: \"Hemos rodeado ese \xE1rbol
    tres veces.\"}\r\n- CharacterID: Jared\r\n  LineID: L_2ffe5ce2626e\r\n  LocalizedDialogue:
    {en: \"It's a popular tree. Five stars on TreeAdvisor.\", fr: \"C'est un arbre
    populaire. Cinq \xE9toiles sur TreeAdvisor.\", es: \"Es un \xE1rbol famoso. Cinco
    estrellas en TreeAdvisor.\"}\r\n- CharacterID: Ava\r\n  LineID: L_112bf2e87589\r\n 
    LocalizedDialogue: {en: \"Shh! Did you hear that?\", fr: \"Chut! T'as entendu
    \xE7a ?\", es: \"\xA1Shh! \xBFEscuchaste eso?\"}\r\n- CharacterID: Jared\r\n 
    LineID: L_c44c7409c2ef\r\n  LocalizedDialogue: {en: \"Maybe it's a bear. Or a
    ranger with snacks.\", fr: \"Peut-\xEAtre un ours. Ou un garde forestier avec
    des snacks.\", es: \"Quiz\xE1s un oso. O un guardabosques con bocadillos.\"}\r\n-
    CharacterID: Wolfstag\r\n  LineID: L_1c7e5ac65392\r\n  LocalizedDialogue: {en:
    \"*A towering silhouette appears between the trees. Antlers like twisted branches.*\",
    fr: \"*Une silhouette massive \xE9merge entre les arbres. Des bois torsad\xE9s.*\",
    es: \"*Una silueta imponente aparece entre los \xE1rboles. Astas retorcidas.*\"}\r\n-
    CharacterID: Ava\r\n  LineID: L_3bb8eeae38a4\r\n  LocalizedDialogue: {en: \"What
    is *that?!*\", fr: \"C'est quoi *\xE7a* ?!\", es: \"\xBF\xA1Qu\xE9 es *eso*!?\"}\r\n-
    CharacterID: Jared\r\n  LineID: L_9f46070601ab\r\n  LocalizedDialogue: {en: \"*gasps*
    Whoooooa. Look at you!\", fr: \"*hal\xE8tement* Wooooow. Regarde-moi \xE7a!\",
    es: \"*jadea* \xA1Wooooow! \xA1M\xEDrate!\"}\r\n- CharacterID: Jared\r\n  LineID:
    L_dba9fd3bc92d\r\n  LocalizedDialogue: {en: \"Are you lost too, buddy? You need
    scritches? Huh? Who's a majestic forest beast? *You* are!\", fr: \"Tu t'es perdu
    aussi, mon grand ? Tu veux des gratouilles ? Qui est une b\xEAte majestueuse
    ? *C'est toi!*\", es: \"\xBFTambi\xE9n est\xE1s perdido, amigo? \xBFQuieres caricias?
    \xBFQui\xE9n es una bestia majestuosa? \xA1*T\xFA*!\"}\r\n- CharacterID: Wolfstag\r\n 
    LineID: L_bf5d37ca2a32\r\n  LocalizedDialogue: {en: \"*It tilts its head slightly.
    Curious.*\", fr: \"*Il incline l\xE9g\xE8rement la t\xEAte. Curieux.*\", es:
    \"*Inclina ligeramente la cabeza. Curioso.*\"}\r\n- CharacterID: Ava\r\n  LineID:
    L_bf8a1eb8aa0a\r\n  LocalizedDialogue: {en: \"Jared\u2026 stop trying to pet
    the antler demon!\", fr: \"Jared\u2026 arr\xEAte d'essayer de caresser le d\xE9mon
    \xE0 bois!\", es: \"\xA1Jared... deja de intentar acariciar al demonio de los
    cuernos!\"}\r\n- CharacterID: Wolfstag\r\n  LineID: L_13b0e5e2ffdd\r\n  LocalizedDialogue:
    {en: \"*The shadows melt away. The creature's full form is revealed\u2014fur
    glows silver in the moonlight.*\", fr: \"*Les ombres se dissipent. La cr\xE9ature
    se d\xE9voile \u2014 sa fourrure luit \xE0 la lumi\xE8re lunaire.*\", es: \"*Las
    sombras se desvanecen. Su forma completa aparece \u2014 su pelaje brilla bajo
    la luna.*\"}\r\n- CharacterID: Jared\r\n  LineID: L_92dfaaba4797\r\n  LocalizedDialogue:
    {en: \"Oh my god. He's gorgeous. I want ten of him.\", fr: \"Oh mon dieu. Il
    est splendide. J'en veux dix.\", es: \"Dios m\xEDo. Es hermoso. Quiero diez.\"}\r\n-
    CharacterID: Ava\r\n  LineID: L_085560b0636b\r\n  LocalizedDialogue: {en: \"...I
    think he's leading us somewhere.\", fr: \"...Je crois qu'il nous guide quelque
    part.\", es: \"...Creo que nos est\xE1 guiando.\"}\r\n- CharacterID: Wolfstag\r\n 
    LineID: L_43754d2364f0\r\n  LocalizedDialogue: {en: \"*He glances back, takes
    a few careful steps, then waits.*\", fr: \"*Il jette un regard en arri\xE8re,
    avance lentement, puis s'arr\xEAte.*\", es: \"*Mira hacia atr\xE1s, da unos pasos
    y espera.*\"}\r\n- CharacterID: Jared\r\n  LineID: L_64bb810760fa\r\n  LocalizedDialogue:
    {en: \"Look at him! He's so polite. Trail angel confirmed.\", fr: \"Regarde-le
    ! Trop poli. Ange du sentier confirm\xE9.\", es: \"\xA1M\xEDralo! Tan educado.
    \xC1ngel del sendero confirmado.\"}\r\n- CharacterID: Ava\r\n  LineID: L_8c74f64fbda9\r\n 
    LocalizedDialogue: {en: \"I think he wants us to follow. And... I think we should.\",
    fr: \"Il veut qu'on le suive. Et... je crois qu'on devrait.\", es: \"Quiere que
    lo sigamos. Y... creo que debemos hacerlo.\"}\r\n- CharacterID: Wolfstag\r\n 
    LineID: L_e9dc14c0ea88\r\n  LocalizedDialogue: {en: \"*The creature moves ahead
    again, parting the brush. Bits of a path peek through behind him.*\", fr: \"*La
    cr\xE9ature avance \xE0 nouveau, \xE9cartant les buissons. Un sentier appara\xEEt
    derri\xE8re lui.*\", es: \"*La criatura avanza, apartando los arbustos. Se revela
    un sendero detr\xE1s de \xE9l.*\"}\r\n- CharacterID: Jared\r\n  LineID: L_06bfb201f71e\r\n 
    LocalizedDialogue: {en: \"Wait... this looks familiar. That's the ridge! That's
    the way back!\", fr: \"Attends... \xE7a me dit quelque chose. C'est la cr\xEAte
    ! C'est le bon chemin!\", es: \"Espera... esto me suena. \xA1Esa es la cresta!
    \xA1Ese es el camino de regreso!\"}\r\n- CharacterID: Ava\r\n  LineID: L_9b259bdc23c5\r\n 
    LocalizedDialogue: {en: \"He really *is* guiding us...\", fr: \"Il nous guide
    vraiment...\", es: \"De verdad nos est\xE1 guiando...\"}\r\n- CharacterID: Wolfstag\r\n 
    LineID: L_0be9debd88d5\r\n  LocalizedDialogue: {en: \"*He pauses at the clearing's
    edge, makes eye contact, then silently disappears into the mist.*\", fr: \"*Il
    s'arr\xEAte \xE0 la lisi\xE8re de la clairi\xE8re, nous regarde, puis dispara\xEEt
    dans la brume.*\", es: \"*Se detiene en el borde del claro, nos mira y desaparece
    entre la niebla.*\"}\r\n- CharacterID: Jared\r\n  LineID: L_6823bc528fb1\r\n 
    LocalizedDialogue: {en: \"...Goodbye, magic antler puppy. I hope you find your
    own trail home.\", fr: \"...Adieu, chien magique \xE0 bois. J'esp\xE8re que tu
    retrouveras ton chemin.\", es: \"...Adi\xF3s, cachorro m\xE1gico de astas. Ojal\xE1
    encuentres tu camino.\"}\r\n- CharacterID: Ava\r\n  LineID: L_a67f079b7895\r\n 
    LocalizedDialogue: {en: \"...Next time, I'm bringing a map and a compass. And
    maybe pepper spray.\", fr: \"...La prochaine fois, je prends une carte, une boussole...
    et du spray au poivre.\", es: \"...La pr\xF3xima vez, llevar\xE9 un mapa, una
    br\xFAjula... y tal vez gas pimienta.\"}\r\n"
